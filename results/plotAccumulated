def generate_timeseries_profile_all(model_path, mode, var, ninterval, nwindow, depth_pct=None, horizontal_pct=None):
    # extract time series information from all the model folders,
    # and return them in the array data.
    filenames = glob.glob(model_path+'/fault.?????.nc')
    filenames = sort_nicely(filenames)
    num_files = len(filenames)

    # fault.r.nc must exist
    # extract dimension information from restart file.
    a = xr.open_dataset(model_path+'/fault.r.nc')
    shear_strike = a.shear_strike
    num_rows = shear_strike.shape[0]
    num_cols = shear_strike.shape[1]
    
    # Calculate indices based on percentages
    if mode == 1:  # Vertical profile - need horizontal position
        if horizontal_pct is not None:
            col_index = int(round((horizontal_pct / 100.0) * (num_cols - 1)))
            col_index = max(0, min(col_index, num_cols - 1))
            actual_horizontal_pct = (col_index / (num_cols - 1)) * 100
        else:
            col_index = num_cols // 2
            actual_horizontal_pct = (col_index / (num_cols - 1)) * 100
        row_index = None
        actual_depth_pct = None
        print(f'Vertical profile at {actual_horizontal_pct:.1f}% along strike (column {col_index})')
    elif mode == 2:  # Horizontal profile - need depth position
        if depth_pct is not None:
            # Note: depth_pct=100 is top (high row index), depth_pct=0 is bottom (low row index)
            row_index = int(round((depth_pct / 100.0) * (num_rows - 1)))
            row_index = max(0, min(row_index, num_rows - 1))
            actual_depth_pct = (row_index / (num_rows - 1)) * 100
        else:
            row_index = num_rows // 4 * 3  # Default to 3/4 depth as before
            actual_depth_pct = (row_index / (num_rows - 1)) * 100
        col_index = None
        actual_horizontal_pct = None
        print(f'Horizontal profile at {actual_depth_pct:.1f}% depth (row {row_index})')

    print(f'Grid dimensions: {num_files} files, {num_rows} rows, {num_cols} cols')

    if mode == 1:
        # plot vertical profile, count rows
        data = np.zeros((num_rows, num_files))
        data_ave = np.zeros((num_rows-nwindow+1, num_files))
    elif mode == 2:
        # plot horizontal profile, count columns
        data = np.zeros((num_cols, num_files))
        data_ave = np.zeros((num_cols-nwindow+1, num_files))
    
    itag = 0
    for file1 in filenames:
        b = xr.open_dataset(file1)
        if var == 'effective_normal':
            res = b.effective_normal
            res = res/1.e6
            
        elif var == 'slip_rate':
            res = b.slip_rate
            
        elif var == 'shear_strike':
            res = b.shear_strike
            res = res/1.e6
            
        elif var == 'slips':
            res = b.slips
            
        elif var == 'slipd':
            res = b.slipd
            
        itag = itag + 1
        if mode == 1:
            data[:,itag-1] = res[:, col_index]
        elif mode == 2:
            for i in range(num_cols):
                data[i,itag-1] = res[row_index,i]
        
        data_ave[:,itag-1] = boxcar_average(data[:,itag-1],nwindow) 
        
    data0 = data_ave[:,::ninterval]
    return data0, actual_depth_pct, actual_horizontal_pct # [# of nodes, # of steps], depth%, horizontal%

def plot_accumulated_slip(mode, ncyc, nwindow, var_name, depth_pct=None, horizontal_pct=None):
    """Plot accumulated slip across all cycles"""
    # Generate position string for filename
    if mode == 1:  # Vertical profile
        pos_str = f"h{horizontal_pct:.1f}pct"
        xlabel = 'Along Dip on-fault Nodes'
        profile_type = 'Vertical'
    else:  # Horizontal profile
        pos_str = f"d{depth_pct:.1f}pct"
        xlabel = 'Along Strike on-fault Nodes'
        profile_type = 'Horizontal'
    
    if var_name == 'slips':
        ylabel = 'Strike Slip (m)'
        slip_type = 'Strike Slips'
        print(f'Generating accumulated strike slips on a {profile_type.lower()} profile')
    elif var_name == 'slipd':
        ylabel = 'Dip Slip (m)'
        slip_type = 'Dip Slips'
        print(f'Generating accumulated dip slips on a {profile_type.lower()} profile')
        
    out_file = f'c{profile_type}Profile.{var_name}.{pos_str}.png'
        
    for i in range(ncyc):
        model_path = 'Q'+str(i) 
        print('Processing the '+str(i)+'th cycle')
        tmp, actual_depth_pct, actual_horizontal_pct = generate_timeseries_profile_all(
            model_path, mode, var_name, ninterval, nwindow, depth_pct, horizontal_pct)
        if i == 0:
            data = tmp
        else:
            # adding final slip from last batch to the new data - tmp.
            result = tmp + data[:, -1, np.newaxis] 
            data = np.concatenate((data, result), axis=1)
        
    num_cols = data.shape[1]
    print('Plot every', ninterval, 'steps')
    print('Total time steps are', num_cols)
    
    # Create title with actual percentages
    slip_type = 'Strike Slips' if mode in [1, 2] else 'Dip Slips'
    if mode == 1:
        title = f'Accumulated {slip_type} on {profile_type} Profile at {actual_horizontal_pct:.1f}% Along Strike'
    else:
        title = f'Accumulated {slip_type} on {profile_type} Profile at {actual_depth_pct:.1f}% Depth'
    
    plt.figure(figsize=(8, 6))
    # Use consistent colormap for accumulated slip
    colors = plt.cm.viridis(np.linspace(0, 1, num_cols))
    for i in range(num_cols):
        plt.plot(data[:,i], color=colors[i], linewidth=1)
        
    plt.xlabel(xlabel, fontweight='bold')
    plt.ylabel(ylabel, fontweight='bold')
    plt.title(title, fontweight='bold')
    plt.tight_layout()
    plt.savefig(out_file, dpi=300)
    print(f'Saved: {out_file}')

def plot_stress_cycle_by_cycle(mode, ncyc, nwindow, var, depth_pct=None, horizontal_pct=None):
    """Plot stress variables cycle by cycle"""
    if var == 'effective_normal':
        ylabel = 'Effective Normal Stress (MPa)'
        var_name = 'Effective Normal Stress'
    elif var == 'shear_strike':
        ylabel = 'Shear Stress (MPa)'
        var_name = 'Shear Stress'
    elif var == 'slip_rate':
        ylabel = 'Slip Rate (m/s)'
        var_name = 'Slip Rate'
    else:
        print(f"Unknown variable: {var}")
        return
        
    if mode == 1:
        xlabel = 'Along Dip on-fault Nodes'
        profile_type = 'Vertical'
    elif mode == 2:
        xlabel = 'Along Strike on-fault Nodes'
        profile_type = 'Horizontal'
        
    plt.figure(figsize=(8, 6))
    
    colors = plt.cm.viridis(np.linspace(0, 1, ncyc))
    
    for i in range(ncyc):
        model_path = 'Q'+str(i)
        print(f'Processing cycle {i} for {var_name}')
        data, actual_depth_pct, actual_horizontal_pct = generate_timeseries_profile_all(
            model_path, mode, var, ninterval, nwindow, depth_pct, horizontal_pct)
        
        # Plot each time step in this cycle
        num_steps = data.shape[1]
        for j in range(0, num_steps, max(1, num_steps//5)):  # Plot every 5th step to avoid overcrowding
            alpha = 0.3 + 0.7 * (j / (num_steps - 1)) if num_steps > 1 else 1.0
            plt.plot(data[:,j], color=colors[i], alpha=alpha, linewidth=1, 
                    label=f'Cycle {i}' if j == 0 else "")
    
    # Create title with actual percentages
    if mode == 1:
        title = f'{var_name} on {profile_type} Profile at {actual_horizontal_pct:.1f}% Along Strike - Cycle by Cycle'
    else:
        title = f'{var_name} on {profile_type} Profile at {actual_depth_pct:.1f}% Depth - Cycle by Cycle'
    
    plt.xlabel(xlabel, fontweight='bold')
    plt.ylabel(ylabel, fontweight='bold')
    plt.title(title, fontweight='bold')
    plt.legend(bbox_to_anchor=(1.05, 1), loc='upper left', prop={'weight': 'bold'})
    plt.tight_layout()
    
    # Generate position string for filename
    if mode in [1, 3]:  # Vertical profiles
        pos_str = f"h{actual_horizontal_pct:.1f}pct"
    else:  # Horizontal profiles  
        pos_str = f"d{actual_depth_pct:.1f}pct"
    
    out_file = f'c{profile_type}Profile.{var}.cycles.{pos_str}.png'
    plt.savefig(out_file, dpi=300, bbox_inches='tight')
    print(f'Saved: {out_file}')

def plot_all_variables(ncyc, nwindow, depth_pct=None, horizontal_pct=None):
    """Plot all variables for both modes: slip (accumulated) and others (cycle by cycle)"""
    print("\n=== Plotting All Variables for Both Modes ===")
    
    modes = [1, 2]  # Vertical and Horizontal
    mode_names = {1: "Vertical", 2: "Horizontal"}
    slip_vars = ['slips', 'slipd']  # Both strike and dip slip
    stress_vars = ['effective_normal', 'shear_strike', 'slip_rate']
    
    generated_files = []
    
    for mode in modes:
        print(f"\n--- Processing {mode_names[mode]} Profile (Mode {mode}) ---")
        
        # Get actual percentages by calling the data generation function once
        model_path = 'Q0'  # Just to get the percentages
        try:
            _, actual_depth_pct, actual_horizontal_pct = generate_timeseries_profile_all(
                model_path, mode, 'slips', 1, nwindow, depth_pct, horizontal_pct)
        except:
            # Fallback to input values if function fails
            actual_depth_pct = depth_pct if depth_pct else 75.0
            actual_horizontal_pct = horizontal_pct if horizontal_pct else 50.0
        
        # Generate position string for output listing
        if mode == 1:  # Vertical profile
            pos_str = f"h{actual_horizontal_pct:.1f}pct"
        else:  # Horizontal profile
            pos_str = f"d{actual_depth_pct:.1f}pct"
        
        # Plot accumulated slip variables
        for i, slip_var in enumerate(slip_vars, 1):
            print(f"\n{i}. Processing {slip_var} (accumulated across cycles)...")
            plot_accumulated_slip(mode, ncyc, nwindow, slip_var, depth_pct, horizontal_pct)
            generated_files.append(f"c{mode_names[mode]}Profile.{slip_var}.{pos_str}.png")
        
        # Plot stress variables cycle by cycle
        for i, var in enumerate(stress_vars, len(slip_vars)+1):
            print(f"\n{i}. Processing {var} (cycle by cycle)...")
            plot_stress_cycle_by_cycle(mode, ncyc, nwindow, var, depth_pct, horizontal_pct)
            generated_files.append(f"c{mode_names[mode]}Profile.{var}.cycles.{pos_str}.png")
    
    print("\n=== All plots completed! ===")
    print("Generated files:")
    for file in generated_files:
        print(f"  - {file}")

def get_user_input():
    """Interactive terminal interface for selecting plotting options"""
    print("\n=== Plot Accumulated Variables ===")
    print("This tool can plot variables from fault.X.nc files")
    print("Available variables:")
    print("  - slips: accumulated strike slip")
    print("  - slipd: accumulated dip slip")
    print("  - effective_normal: effective normal stress (cycle by cycle)")
    print("  - shear_strike: shear stress (cycle by cycle)")
    print("  - slip_rate: slip rate (cycle by cycle)")
    print("  - all: plot ALL variables for BOTH modes (comprehensive output)")
    print()
    
    # Get variable selection
    while True:
        var_choice = input("Select variable (slips/slipd/effective_normal/shear_strike/slip_rate/all): ").strip().lower()
        if var_choice in ['slips', 'slipd', 'effective_normal', 'shear_strike', 'slip_rate', 'all']:
            break
        print("Invalid choice. Please enter 'slips', 'slipd', 'effective_normal', 'shear_strike', 'slip_rate', or 'all'")
    
    # Get profile mode (skip for 'all' option)
    mode = None
    if var_choice != 'all':
        while True:
            try:
                print("Profile modes:")
                print("  1 = Vertical profile")
                print("  2 = Horizontal profile")
                mode = int(input("Select profile mode (1-2): "))
                if mode in [1, 2]:
                    break
                print("Invalid choice. Please enter 1 or 2")
            except ValueError:
                print("Please enter a number (1-2)")
    
    # Get position selection - single percentage applies to both modes
    while True:
        try:
            pos_input = input("Position percentage (0-100%, default=50%): ").strip()
            if pos_input == "":
                pct = 50.0
                break
            pct = float(pos_input)
            if 0 <= pct <= 100:
                break
            print("Position must be between 0 and 100%")
        except ValueError:
            print("Please enter a number between 0 and 100")
    
    # Apply the same percentage to both horizontal and vertical profiles
    horizontal_pct = pct  # For vertical profiles
    depth_pct = pct       # For horizontal profiles
    
    # Get number of cycles
    while True:
        try:
            ncyc = int(input("Number of cycles to process: "))
            if ncyc > 0:
                break
            print("Number of cycles must be positive")
        except ValueError:
            print("Please enter a positive integer")
    
    # Get window size for averaging
    while True:
        try:
            nwindow = int(input("Window size for averaging (default=1): ") or "1")
            if nwindow > 0:
                break
            print("Window size must be positive")
        except ValueError:
            print("Please enter a positive integer")
    
    return var_choice, mode, ncyc, nwindow, depth_pct, horizontal_pct

def tryint(s):
    try:
        return int(s)
    except:
        return s

def alphanum_key(s):
    return [tryint(c) for c in re.split('([0-9]+)', s)]

def sort_nicely(l):
    l.sort(key=alphanum_key, reverse=False)
    return l

