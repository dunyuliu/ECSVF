            plot_accumulated_slip(mode, ncyc, nwindow, var_choice, depth_pct, horizontal_pct)
        else:
            plot_stress_cycle_by_cycle(mode, ncyc, nwindow, var_choice, depth_pct, horizontal_pct)
            
    elif len(sys.argv) == 2 and sys.argv[1] == '-h':
