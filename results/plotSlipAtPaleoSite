def extract_slip_at_station(model_path, station_pct, ninterval):
    """Extract slip time series at a single station at free surface (depth 100%)"""
    filenames = glob.glob(model_path+'/fault.?????.nc')
    filenames = sort_nicely(filenames)
    num_files = len(filenames)
    
    if num_files == 0:
        print(f"No fault files found in {model_path}")
        return None, None, None
    
    global_time = np.loadtxt(model_path + '/global.dat', usecols=0)

    # Get grid dimensions from restart file
    restart_file = model_path + '/fault.r.nc'
    if not os.path.exists(restart_file):
        print(f"Restart file not found: {restart_file}")
        return None, None, None
        
    a = xr.open_dataset(restart_file)
    shear_strike = a.shear_strike
    num_rows = shear_strike.shape[0]
    num_cols = shear_strike.shape[1]
    
    # Calculate station position
    col_index = int(round((station_pct / 100.0) * (num_cols - 1)))
    col_index = max(0, min(col_index, num_cols - 1))
    actual_station_pct = (col_index / (num_cols - 1)) * 100
    
    # Free surface is at depth 100% (bottom row index)
    row_index = num_rows - 1
    
    print(f'Grid dimensions: {num_files} files, {num_rows} rows, {num_cols} cols')
    print(f'Station at {actual_station_pct:.1f}% along strike (column {col_index})')
    print(f'Free surface at depth 100% (row {row_index})')
    
    # Extract slip time series
    slip_data = np.zeros(num_files)
    time_steps = []
    time_seconds = []
    for i, filename in enumerate(filenames):
        b = xr.open_dataset(filename)
        slip_data[i] = b.slips[row_index, col_index]
        
        # Extract time step from filename (fault.XXXXX.nc)
        time_step = int(filename.split('.')[-2])
        time_steps.append(time_step)
        time_seconds.append(global_time[time_step-1])
    
    # Subsample based on ninterval
    if ninterval > 1:
        slip_data = slip_data[::ninterval]
        time_steps = time_steps[::ninterval]
    
    return slip_data, time_steps, actual_station_pct, time_seconds

def plot_accumulated_slip_at_station(ncyc, station_pct, ninterval=1, slip_threshold=0.1):
    """Plot accumulated slip at a single station across all cycles"""
    print(f"\n=== Plotting Accumulated Slip at Paleoseismic Site ===")
    print(f"Station position: {station_pct}% along strike")
    print(f"Depth: 100% (free surface)")
    
    all_slip_data = []
    all_time_steps = []
    all_time_seconds = []
    cycle_boundaries = [0]  # Track where each cycle starts/ends
    
    for i in range(ncyc):
        model_path = 'Q' + str(i)
        print(f'\nProcessing cycle {i}...')
        
        slip_data, time_steps, actual_station_pct, time_seconds = extract_slip_at_station(model_path, station_pct, ninterval)
        
        if slip_data is None:
            print(f"Skipping cycle {i} due to missing data")
            continue
            
        if i == 0:
            # First cycle - use as is
            all_slip_data.extend(slip_data)
            all_time_steps.extend(time_steps)
            all_time_seconds.extend(time_seconds)
        else:
            # Subsequent cycles - add to accumulated slip from previous cycles
            accumulated_offset = all_slip_data[-1] if all_slip_data else 0
            accumulated_slip = slip_data + accumulated_offset
            all_slip_data.extend(accumulated_slip)

            # Adjust time steps to be continuous
            time_offset = all_time_steps[-1] + (time_steps[1] - time_steps[0]) if all_time_steps else 0
            adjusted_time_steps = [t + time_offset for t in time_steps]
            all_time_steps.extend(adjusted_time_steps)

            # Adjust time in seconds to be continuous
            time_offset_seconds = all_time_seconds[-1] + (time_seconds[1] - time_seconds[0]) if all_time_seconds else 0
            adjusted_time_seconds = [t + time_offset_seconds for t in time_seconds]
            all_time_seconds.extend(adjusted_time_seconds)
        
        cycle_boundaries.append(len(all_slip_data))
    
    if not all_slip_data:
        print("No data to plot!")
        return
    
    # Convert to numpy arrays
    all_slip_data = np.array(all_slip_data)
    all_time_steps = np.array(all_time_steps)
    all_time_seconds = np.array(all_time_seconds)

    # Convert time to different units
    time_days = all_time_seconds / (24 * 3600)
    time_years = time_days / 365.25
    
    print(f"\nTotal data points: {len(all_slip_data)}")
    print(f"Final accumulated slip: {all_slip_data[-1]:.3f} m")
    print(f"Total time: {time_years[-1]:.2f} years ({time_days[-1]:.1f} days)")
    
    # Detect earthquake events based on Q folder slip increments
    def detect_events_by_slip_threshold(cycle_boundaries, slip_data, time_data, threshold=0.1):
        """Detect earthquake events by Q folder slip accumulation with threshold"""
        event_times = []
        event_slip_values = []
        event_q_ranges = []  # Track which Q folders are included in each event
        accumulated_slip = 0.0
        event_start_q = 0
        
        print(f"\nAnalyzing Q folders with slip threshold: {threshold} m")
        
        for i in range(len(cycle_boundaries)-1):
            start_idx = cycle_boundaries[i]
            end_idx = cycle_boundaries[i+1] - 1
            
            if start_idx < len(slip_data) and end_idx < len(slip_data):
                # Calculate slip increment for this Q folder
                slip_increment = slip_data[end_idx] - slip_data[start_idx]
                accumulated_slip += slip_increment
                
                print(f"  Q{i}: slip increment = {slip_increment:.3f} m, accumulated = {accumulated_slip:.3f} m")
                
                # Check if accumulated slip exceeds threshold
                if accumulated_slip >= threshold:
                    # This completes an earthquake event
                    event_time = time_data[end_idx]  # Time at end of this Q folder
                    event_slip = slip_data[end_idx]  # Total slip at this point
                    
                    event_times.append(event_time)
                    event_slip_values.append(event_slip)
                    event_q_ranges.append((event_start_q, i))  # Q range for this event
                    
                    print(f"    -> EVENT detected! Q{event_start_q}-Q{i}, total slip: {event_slip:.3f} m")
                    
                    # Reset for next event
                    accumulated_slip = 0.0
                    event_start_q = i + 1
        
        return event_times, event_slip_values, event_q_ranges
    
    # Use the provided slip threshold for earthquake detection
    event_times, event_slip_values, event_q_ranges = detect_events_by_slip_threshold(
        cycle_boundaries, all_slip_data, time_years, slip_threshold)
    
    # Calculate recurrence times between earthquake events
    recurrence_times = []
    if len(event_times) > 1:
        for i in range(1, len(event_times)):
            recurrence_time = event_times[i] - event_times[i-1]
            recurrence_times.append(recurrence_time)
    
    print(f"\nDetected {len(event_times)} earthquake events:")
    for i, (time_val, slip_val, q_range) in enumerate(zip(event_times, event_slip_values, event_q_ranges)):
        q_start, q_end = q_range
        if q_start == q_end:
            q_str = f"Q{q_start}"
        else:
            q_str = f"Q{q_start}-Q{q_end}"
        print(f"  Event {i+1}: {q_str}, t={time_val:.2f} years, slip={slip_val:.3f} m")
    
    # Create two subplots with improved styling
    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(8, 10))
    
    # Enhanced colors for better visibility
    colors = ['#d62728', '#2ca02c', '#ff7f0e', '#9467bd', '#8c564b', '#e377c2', '#7f7f7f', '#bcbd22']
    
    # Plot 1: Time in years
    ax1.plot(time_years, all_slip_data, '#1f77b4', linewidth=2.5, label='Accumulated Slip', zorder=3)
    
    # Add earthquake event markers for years plot
    num_events = len(event_times)
    show_legend = num_events <= 10  # Only show legend if 10 or fewer events
    
    for i, event_time in enumerate(event_times):
        color = colors[i % len(colors)]
        label = f'Event {i+1}' if show_legend else None
        ax1.axvline(x=event_time, color=color, linestyle='--', alpha=0.8, 
                   linewidth=2, label=label, zorder=2)
    
    # Also keep Q folder boundaries as light gray lines for reference
    for i in range(1, len(cycle_boundaries)-1):
        boundary_idx = cycle_boundaries[i] - 1
        if boundary_idx < len(time_years):
            ax1.axvline(x=time_years[boundary_idx], color='lightgray', linestyle=':', alpha=0.5, 
                       linewidth=1, zorder=1)
    
    # Add recurrence time labels for earthquake events
    for i in range(len(event_times)):
        event_time = event_times[i]
        event_slip = event_slip_values[i]
        q_start, q_end = event_q_ranges[i]
        
        # Position label above the curve
        y_range = np.max(all_slip_data) - np.min(all_slip_data)
        label_offset = y_range * 0.08  # 8% of total range above the curve
        label_y = event_slip + label_offset
        
        # Create label text with Q range and recurrence time
        if q_start == q_end:
            q_str = f"Q{q_start}"
        else:
            q_str = f"Q{q_start}-{q_end}"
        
        if i > 0 and i-1 < len(recurrence_times):
            recur_time = recurrence_times[i-1]
            label_text = f'E{i+1}\n{q_str}\n{recur_time:.1f}y'
        else:
            label_text = f'E{i+1}\n{q_str}'
        
        # Add label on top of curve
        ax1.text(event_time, label_y, label_text, 
                horizontalalignment='center', verticalalignment='bottom',
                bbox=dict(boxstyle='round,pad=0.3', facecolor='yellow', alpha=0.8, edgecolor='orange'),
                fontsize=9, fontweight='bold', zorder=4)
    
    ax1.set_xlabel('Time (years)', fontweight='bold')
    ax1.set_ylabel('Accumulated Slip (m)', fontweight='bold')
    ax1.set_title(f'Accumulated Slip at Paleoseismic Site\n({actual_station_pct:.1f}% Along Strike, Free Surface)', 
                  fontweight='bold', pad=20)
    ax1.grid(True, alpha=0.4, linestyle='-', linewidth=0.5)
    if show_legend:
        ax1.legend(frameon=True, framealpha=0.9, edgecolor='black', fancybox=False, 
                  loc='upper left', ncol=2 if num_events > 5 else 1)
    else:
        # Add a note about events when legend is hidden
        ax1.text(0.02, 0.98, f'Dashed lines: earthquake events ({num_events} events)', 
                transform=ax1.transAxes, verticalalignment='top',
                bbox=dict(boxstyle='round,pad=0.3', facecolor='white', alpha=0.8, edgecolor='gray'),
                fontsize=9)
    
    # Add note about Q folder boundaries
    ax1.text(0.02, 0.92, f'Dotted lines: Q folder boundaries ({len(cycle_boundaries)-1} folders)', 
            transform=ax1.transAxes, verticalalignment='top',
            bbox=dict(boxstyle='round,pad=0.3', facecolor='lightgray', alpha=0.6, edgecolor='gray'),
            fontsize=8)
    ax1.set_axisbelow(True)
    
    # Plot 2: Time steps
    ax2.plot(all_time_steps, all_slip_data, '#d62728', linewidth=2.5, label='Accumulated Slip', zorder=3)
    
    # Add earthquake event markers for time steps plot
    for i, event_time in enumerate(event_times):
        # Find closest time step index for this event time
