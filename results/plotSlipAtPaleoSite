                bbox=dict(boxstyle='round,pad=0.3', facecolor='yellow', alpha=0.8, edgecolor='orange'),
                fontsize=9, fontweight='bold', zorder=4)
    
    plt.xlabel('Time (years)', fontweight='bold')
    plt.ylabel('Accumulated Slip (m)', fontweight='bold')
    plt.title(f'Accumulated Slip at Paleoseismic Site - Years\n({actual_station_pct:.1f}% Along Strike)', 
