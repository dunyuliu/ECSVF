def get_user_input():
    """Interactive terminal interface for selecting station and cycles"""
    print("\n=== Plot Slip at Paleoseismic Site ===")
    print("This tool plots accumulated slip at a single station at the free surface (depth 100%)")
    print("Useful for analyzing paleoseismic sites and long-term slip accumulation")
    print()
    
    # Get station position
    while True:
        try:
            pos_input = input("Station position along strike (0-100%, default=50%): ").strip()
            if pos_input == "":
                station_pct = 50.0
                break
            station_pct = float(pos_input)
            if 0 <= station_pct <= 100:
                break
            print("Position must be between 0 and 100%")
        except ValueError:
            print("Please enter a number between 0 and 100")
    
    # Get number of cycles
    while True:
        try:
            ncyc = int(input("Number of cycles to process: "))
            if ncyc > 0:
                break
            print("Number of cycles must be positive")
        except ValueError:
            print("Please enter a positive integer")
    
    # Get time step interval
    while True:
        try:
            ninterval = int(input("Time step interval (1=every step, 10=every 10th step, default=1): ") or "1")
            if ninterval > 0:
                break
            print("Interval must be positive")
        except ValueError:
            print("Please enter a positive integer")
    
    # Get slip threshold for earthquake detection
    while True:
        try:
            slip_input = input("Slip threshold for earthquake detection (m, default=0.1): ").strip()
            if slip_input == "":
                slip_threshold = 0.1
                break
            slip_threshold = float(slip_input)
            if slip_threshold > 0:
                break
            print("Slip threshold must be positive")
        except ValueError:
            print("Please enter a positive number")
    
    return station_pct, ncyc, ninterval, slip_threshold

def tryint(s):
    try:
        return int(s)
    except:
        return s

def alphanum_key(s):
    return [tryint(c) for c in re.split('([0-9]+)', s)]

def sort_nicely(l):
    l.sort(key=alphanum_key, reverse=False)
    return l

